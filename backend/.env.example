# ============================
# AI Content OS — Environment
# ============================
# Sao chép file này thành .env và điền giá trị thực

# === App ===
APP_NAME="AI Content OS"
DEBUG=false

# === AI Run Mode: cloud | local ===
RUN_MODE=cloud

# === AI Provider (cloud mode): google | openai | anthropic ===
AI_PROVIDER=google

# === Cloud API Keys ===
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Model Names ===
PLANNER_MODEL=gemini-1.5-flash
WRITER_MODEL=gemini-1.5-pro
EDITOR_MODEL=gemini-1.5-flash

# === Local Inference (Ollama) ===
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3

# === Search Tools ===
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# === HuggingFace (Phase 2) ===
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# === RAG — Embeddings (Phase 2) ===
# Chọn: huggingface (default, free) | google | openai
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === RAG — ChromaDB (Phase 2) ===
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=knowledge_hub

# === RAG — Chunking (Phase 2) ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# === File Upload (Phase 2) ===
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=["pdf","txt","md","docx"]

# === Server ===
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]
